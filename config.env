# config.env — Central configuration for dnsmasq on Kubernetes nodes.
#
# Edit these values before running any make targets.
# All scripts read from this file. No interactive prompts at runtime.
#
# After editing, run:
#   make demo            (Kind — local cluster)

# ── Shared ──────────────────────────────────────────────────────────

CLUSTER_NAME=dnsmasq-test
WORKER_COUNT=2

# ── Kind (local) ───────────────────────────────────────────────────

# Container runtime: "podman" or "docker"
CONTAINER_CLI=docker

# ── dnsmasq Configuration ──────────────────────────────────────────

# Upstream DNS servers (comma-separated)
UPSTREAM_DNS="8.8.8.8,8.8.4.4"

# Cache size (number of entries)
CACHE_SIZE=1000

# Maximum concurrent DNS forwards
DNS_FORWARD_MAX=10000

# Enable query logging (true/false)
ENABLE_LOGGING=true
